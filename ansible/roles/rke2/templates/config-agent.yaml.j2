server: "{{ rke2_server_url }}"
token: "{{ rke2_join_token }}"
# Voir le commentaire node-ip dans config-server.yaml.j2 — même raison, pas de
# node-external-ip (interdit par RKE2 avec cloud-provider-name: external)
node-ip: "{{ ansible_all_ipv4_addresses | select('match', '^172\\.16\\.') | first }}"

# Cloud Controller Manager fourni séparément par le rôle scaleway-ccm (Phase 2)
cloud-provider-name: external
