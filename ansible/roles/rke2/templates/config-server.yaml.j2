cni: {{ rke2_cni }}
# node-ip = IP privée (réseau Scaleway VPC, eth1) : c'est celle-là que kube-apiserver
# et les autres composants in-cluster (ex. metrics-server) utilisent pour joindre le
# kubelet — le certificat serving kubelet auto-généré n'a de SAN que pour node-ip et
# 127.0.0.1, donc laisser ansible_default_ipv4 (IP publique, eth0) ici casse tout appel
# in-cluster vers le kubelet (logs, exec, port-forward, metrics-server) avec une erreur
# TLS "certificate is valid for ..., not <IP privée>".
# Pas de node-external-ip : interdit par RKE2 avec cloud-provider-name: external
# ("can't set node-external-ip while using cloud provider") — c'est au CCM Scaleway
# de renseigner l'ExternalIP du Node, pas à une config statique.
node-ip: "{{ ansible_all_ipv4_addresses | select('match', '^172\\.16\\.') | first }}"

tls-san:
{% for san in rke2_tls_san %}
  - "{{ san }}"
{% endfor %}

disable:
{% for component in rke2_disable_components %}
  - {{ component }}
{% endfor %}

# Cloud Controller Manager fourni séparément par le rôle scaleway-ccm (Phase 2)
disable-cloud-controller: true
cloud-provider-name: external

write-kubeconfig-mode: "0600"
